{
  "appId": "com.mosaic.puzzle",
  "appName": "Mosaic Puzzle",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0d0d1a",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0d0d1a"
    },
    "Keyboard": {
      "resize": "none"
    }
  },
  "android": {
    "allowMixedContent": true
  }
}
